{
  "internal/*.go": {
    "alternate": "internal/{}_test.go",
    "type": "source"
  },
  "internal/*_test.go": {
    "alternate": "internal/{}.go",
    "type": "test"
  },
  "internal/**/*.go": {
    "alternate": "internal/**/{}_test.go",
    "type": "source"
  },
  "internal/**/*_test.go": {
    "alternate": "internal/**/{}.go",
    "type": "test"
  },
  "cmd/codereview/*.go": {
    "type": "command"
  }
}
